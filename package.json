{
  "name": "sample-social-media",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @social/database db:generate",
    "db:push": "pnpm --filter @social/database db:push",
    "db:migrate": "pnpm --filter @social/database db:migrate",
    "db:studio": "pnpm --filter @social/database db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "ws": ">=8.21.0",
      "multer": ">=2.2.0",
      "js-yaml": ">=4.2.0"
    }
  }
}
