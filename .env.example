# Database
DATABASE_URL="postgresql://social_user:social_pass@localhost:5432/social_media?host=/tmp"

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET="change-me-to-a-random-secret"
JWT_REFRESH_SECRET="change-me-to-another-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
SESSION_SECRET="change-me-to-a-random-secret"
APP_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
FRONTEND_ORIGIN="http://localhost:3000"

# OAuth (set up your app credentials at https://console.cloud.google.com/ and https://github.com/settings/developers)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
